{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build (make)",
			"type": "shell",
			"command": "make",
			"args": [
				"-j"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [
				"$gcc"
			]
		},
